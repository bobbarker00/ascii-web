{
  "manifest_version": 3,
  "name": "ASCII Web",
  "version": "0.2.0",
  "description": "Renders images and videos on any page as live ASCII art using a WebGL2 shader pipeline.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["src/background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ascii-web@wdavis.local",
      "strict_min_version": "115.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ASCII Web",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_idle",
      "all_frames": false,
      "js": [
        "src/glyph-atlas.js",
        "src/shaders.js",
        "src/ascii-renderer.js",
        "src/content.js"
      ]
    }
  ]
}
